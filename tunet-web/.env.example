# Auth.js + Keycloak (OIDC confidential client)
# Generate secret: openssl rand -base64 32
AUTH_SECRET=
# Public URL of this app (e.g. http://localhost:3000 or https://your-domain.vercel.app)
AUTH_URL=http://localhost:3000

# Keycloak realm issuer (must include realm path)
AUTH_KEYCLOAK_ISSUER=https://your-keycloak.example/realms/your-realm
AUTH_KEYCLOAK_ID=your-nextjs-client-id
AUTH_KEYCLOAK_SECRET=your-client-secret

# Valid redirect URI in Keycloak: {AUTH_URL}/api/auth/callback/keycloak

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# RunPod
RUNPOD_API_KEY=rpa_...

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Cron (Vercel injects this automatically, set it here for local dev)
CRON_SECRET=your-random-secret

# Compute provider: "runpod" (default) or "spark"
COMPUTE_PROVIDER=runpod

# Spark Cloud Studio (only needed when COMPUTE_PROVIDER=spark)
SPARK_EMAIL=your-spark-account@email.com
SPARK_PASSWORD=your-spark-password
SPARK_DEFAULT_REGION=us-east-1
SPARK_PROXY_BASE=https://{id}-{port}.proxy.sparkcloud.studio

# Storage — admin uploads this once via /admin/code-bundle
TUNET_CODE_BUNDLE_PATH=admin/tunet-latest.tar.gz
