# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# RunPod
RUNPOD_API_KEY=rpa_...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Cron (Vercel injects this automatically, set it here for local dev)
CRON_SECRET=your-random-secret

# Compute provider: "runpod" (default) or "spark"
COMPUTE_PROVIDER=runpod

# Spark Cloud Studio (only needed when COMPUTE_PROVIDER=spark)
SPARK_EMAIL=your-spark-account@email.com
SPARK_PASSWORD=your-spark-password
SPARK_DEFAULT_REGION=us-east-1
# Proxy URL pattern for pod monitor — ask Walt for the real format
# Placeholders {id} and {port} are replaced at runtime
SPARK_PROXY_BASE=https://{id}-{port}.proxy.sparkcloud.studio

# Storage — admin uploads this once via /admin/code-bundle
TUNET_CODE_BUNDLE_PATH=admin/tunet-latest.tar.gz
